# ─── Streamlit Community Cloud Secrets ─────────────────────────────────────────
# Copy these key-value pairs into your Streamlit Cloud app's Secrets settings:
#   https://share.streamlit.io → Your App → Settings → Secrets
#
# You can also copy this file to .streamlit/secrets.toml for local development.
# NEVER commit secrets.toml to version control.

# ─── Required ────────────────────────────────────────────────────────────────
DEEPINFRA_API_KEY = "your_deepinfra_api_key_here"

# ─── Optional (defaults shown) ───────────────────────────────────────────────
DEEPINFRA_BASE_URL = "https://api.deepinfra.com/v1/openai"
LLM_MODEL_NAME = "meta-llama/Meta-Llama-3.1-8B-Instruct"
LLM_TEMPERATURE = "0.1"
LLM_MAX_TOKENS = "1024"
EMBEDDING_MODEL_NAME = "sentence-transformers/all-MiniLM-L6-v2"
CHUNK_SIZE = "500"
CHUNK_OVERLAP = "50"
CHROMA_COLLECTION_NAME = "upwork_api_docs"
RETRIEVAL_TOP_K = "3"
