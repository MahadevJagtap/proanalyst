# ─── Upwork RAG Bot — Environment Variables ───────────────────────────────────
# Copy this file to .env and populate your values.
# NEVER commit .env to version control.

# ─── Required ────────────────────────────────────────────────────────────────
# Your DeepInfra API key (from https://deepinfra.com/dash)
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# ─── Optional (defaults shown) ───────────────────────────────────────────────
# DeepInfra OpenAI-compatible base URL
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# The Llama model to use on DeepInfra
LLM_MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct

# LLM parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Local embedding model (downloaded automatically by sentence-transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Document chunking parameters (must match assignment: 500 / 50)
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ChromaDB collection name
CHROMA_COLLECTION_NAME=upwork_api_docs

# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=3
